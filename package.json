{
  "name": "claudesign-plugin",
  "version": "0.1.0",
  "description": "Multi-platform Claudesign bundle installer for generic, Codex, Claude, and OpenAI hosts.",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "bin": {
    "claudesign-plugin": "./bin/claudesign-plugin.mjs"
  },
  "files": [
    ".codex-plugin/",
    "adapters/",
    "agents/",
    "bin/",
    "core/",
    "docs/",
    "install.sh",
    "LICENSE.md",
    "README.md",
    "README.zh-CN.md",
    "scripts/",
    "skills/"
  ],
  "scripts": {
    "validate": "ruby scripts/validate_router.rb",
    "designmd:lint": "node ./scripts/designmd.mjs lint ./skills/visual-style/DESIGN.md",
    "designmd:spec": "node ./scripts/designmd.mjs spec --rules",
    "designmd:diff:sample": "node ./scripts/designmd.mjs diff ./docs/designmd-examples/taste-stitch-base.DESIGN.md ./docs/designmd-examples/taste-stitch-variant.DESIGN.md",
    "designmd:export:tailwind": "node ./scripts/designmd.mjs export --format tailwind ./skills/visual-style/DESIGN.md",
    "designmd:export:dtcg": "node ./scripts/designmd.mjs export --format dtcg ./skills/visual-style/DESIGN.md",
    "capability:list": "node ./scripts/capability.mjs list",
    "capability:spec-template": "node ./scripts/capability.mjs spec-template",
    "capability:web-template": "node ./scripts/capability.mjs web-template",
    "capability:contract": "node ./scripts/capability.mjs contract",
    "install:generic": "node ./bin/claudesign-plugin.mjs install --adapter generic",
    "install:claude": "node ./bin/claudesign-plugin.mjs install --adapter claude",
    "install:openai": "node ./bin/claudesign-plugin.mjs install --adapter openai"
  },
  "keywords": [
    "claudesign",
    "plugin",
    "design",
    "codex",
    "claude",
    "openai"
  ]
}
